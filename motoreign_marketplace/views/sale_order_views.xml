<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Action for sale orders -->
    <record id="sale_order_action" model="ir.actions.act_window">
        <field name="name">Order Analysis</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">graph,list,form</field>
    </record>
    <!--        Order Analysis menu-->
    <menuitem id="order-analysis" parent="sales"
              name="Order Analysis" sequence="31"
              groups="multi_vendor_marketplace.multi_vendor_marketplace_admin"
              action="sale_order_action"/>
    <!--        Sale order graph view-->
    <record model="ir.ui.view" id="sale_order_view_graph">
        <field name="name">sale.order.view.graph</field>
        <field name="model">sale.order</field>
        <field name="type">graph</field>
        <field name="arch" type="xml">
            <graph string="Book" type="bar">
                <field name="tax_totals"/>
                <field name="create_date"/>
                <field name="partner_id"/>
            </graph>
        </field>
    </record>
    <!--    Sale order kanban view-->
    <record id="sale_order_view_kanban" model="ir.ui.view">
        <field name="name">sale.order.View.kanban</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="seller_id"/>
                <field name="state"/>
                <field name="unit_price"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click d-flex">
                            <div class="me-3">
                                <t t-if="record.partner_id.raw_value">
                                    <img t-att-src="kanban_image('res.partner', 'avatar_128', record.partner_id.raw_value)"
                                         class=" rounded shadow-sm" style="width: auto; height: auto;"
                                         alt="Partner"/>
                                </t>
                                <t t-else="">
                                    <img src="/base/static/img/avatar_grey.png"
                                         class="rounded shadow-sm"
                                         alt="Partner"/>
                                </t>
                            </div>
                            <div class="oe_kanban_details d-flex flex-column">
                                <div class="o_kanban_record_top">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body mt-1 flex-grow-1">
                                    <div class="text-muted small">
                                        <i class="fa fa-briefcase me-1"/>
                                        <field name="seller_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-2 pt-2 border-top d-flex justify-content-between align-items-center">
                                    <field name="state" widget="label_selection" options="{'classes': {'pending': 'warning', 'approved': 'success', 'shipped': 'info', 'cancel': 'danger', 'draft': 'secondary', 'sent': 'info', 'sale': 'success'}}"/>
                                    <div class="text-primary fw-bold">
                                        <field name="unit_price" widget="monetary"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!--    Sale order form view-->
    <record id="sale_order_view_form" model="ir.ui.view">
        <field name="name">sale.order.view.form</field>
        <field name="model">sale.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="approve_order" type="object"
                            class="oe_highlight"
                            string="Approve" invisible="state != 'pending'"/>
                    <button name="shipped" type="object"
                            class="oe_highlight"
                            string="Ship Now" invisible="state != 'approved'"/>
                    <button name="test" type="object"
                            class="oe_highlight"
                            string="test" invisible="state not in ['sale','sent','draft']"/>
                    <button name="cancel_order" type="object"
                            class="oe_highlight"
                            string="Cancel" invisible="state not in ['pending','shipped']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="approved,shipped"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="product_id"/>
                            <field name="seller_id"/>
                            <field name="quantity"/>
                            <field name="qty_delivered"/>
                            <field name="state"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="partner_id"
                                   context="{'show_address': 1}"/>
                            <field name="company_id"/>
                            <field name="unit_price"/>
                            <field name="discount"/>
                            <field name="subtotal"/>
                            <field name="create_date"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--    Sale order Action-->
    <record id="action_sale_order_view" model="ir.actions.act_window">
        <field name="name">Sale Order</field>
        <field name="res_model">sale.order</field>
        <field name="view_mode">kanban,form</field>
        <field name="domain">[('website_id','!=',False)]</field>
        <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'kanban', 'view_id': ref('sale_order_view_kanban')})]"/>
    </record>
</odoo>
