<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_partner_view_kanban" model="ir.ui.view">
        <field name="name">res.partner.kanban</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image me-1">
                                <field name="image_1920" widget="image"/>
                            </div>
                            <div class="oe_kanban_details">
                                <div class="o_kanban_record_top mb-0">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title"><field name="name"/></strong>
                                    </div>
                                </div>
                                State: <field name="state"/>
                                <div>Email: <field name="email"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="res_partner_action" model="ir.actions.act_window">
        <field name="name">My Profile</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">kanban,form,list</field>
        <field name="view_ids" eval="[(5, 0, 0),(0, 0, {'view_mode': 'kanban', 'view_id': ref('res_partner_view_kanban')})]"/>
    </record>

    <record model="ir.actions.server" id="action_res_partner">
        <field name="name">My Profile</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">action = model.user_my_profile()</field>
    </record>

    <record model="ir.actions.server" id="action_new_res_partner">
        <field name="name">My Profile</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">action = model.new_user_my_profile()</field>
    </record>

    <record id="seller_dashboard_action" model="ir.actions.client">
        <field name="name">Seller Dashboard</field>
        <field name="tag">motoreign_marketplace.seller_dashboard_action</field>
    </record>

    <record id="res_partner_field_view" model="ir.ui.view">
        <field name="name">res.partner.field.view</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Replace vat with profile_url (vat field must exist in parent - use after position) -->
            <field name="vat" position="after">
                <field name="profile_url" string="Profile Url"/>
                <field name="profile_url_value" invisible="1"/>
            </field>
            <field name="vat" position="attributes">
                <attribute name="invisible">1</attribute>
            </field>

            <xpath expr="//notebook/page[5]" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//notebook/page[2]" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//notebook/page[1]" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//notebook/page[3]" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>
            <xpath expr="//notebook/page[4]" position="attributes">
                <attribute name="invisible">True</attribute>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page name="general_information" string="General">
                    <div class="text-muted">
                        <div style="background-color:rgb(208,208,208);padding:10px;margin-bottom:16px;">
                            <h1>Default Settings</h1>
                        </div>
                        <div style="background-color:rgb(245,245,245);padding:10px;">
                            <h3>Default configuration settings can be found here
                                <button type="object" name="view_settings" string="-> Click to View"/>
                            </h3>
                        </div>
                    </div>
                </page>
                <page name="payment" string="Payment">
                    <group>
                        <group>
                            <field name="payment_method_ids" widget="many2many_tags"/>
                            <field name="total_amount"/>
                            <field name="balance_amount"/>
                        </group>
                        <group>
                            <field name="paid_amount"/>
                            <field name="currency_id"/>
                        </group>
                    </group>
                </page>
                <page name="policy" string="Shops and Policies">
                    <group>
                        <group>
                            <field name="seller_shop_id"/>
                            <field name="return_policy"/>
                            <field name="shipping_policy"/>
                        </group>
                        <group/>
                    </group>
                </page>
            </xpath>

            <field name="function" position="attributes">
                <attribute name="invisible">True</attribute>
            </field>
            <field name="category_id" position="attributes">
                <attribute name="invisible">True</attribute>
            </field>
            <button name="action_view_partner_invoices" position="attributes">
                <attribute name="invisible">True</attribute>
            </button>

            <div name="button_box" position="inside">
                <button type="object" name="view_sale_order" class="oe_stat_button" icon="fa-dollar">
                    <field name="sale_count" widget="statinfo" string="Sales"/>
                </button>
                <button class="oe_stat_button" icon="fa-money">
                    <field name="amount_available" widget="statinfo" string="Available"/>
                </button>
                <button type="object" name="view_rating" class="oe_stat_button" icon="fa-star-o">
                    <field name="avg_rating" widget="statinfo" string="Rating"/>
                </button>
                <button type="object" name="view_recommend" class="oe_stat_button" icon="fa-thumbs-o-up">
                    <field name="recommend_count" widget="statinfo" string="Recommendations"/>
                </button>
            </div>

            <xpath expr="//form//sheet" position="before">
                <header>
                    <button type="object" name="register_payment" class="oe_highlight"
                            string="Register for Payment"
                            groups="motoreign_marketplace.motoreign_marketplace_seller"/>
                    <button type="object" name="approve_seller" class="oe_highlight"
                            string="Approve"
                            invisible="state != 'Pending for Approval'"
                            groups="motoreign_marketplace.motoreign_marketplace_admin"/>
                    <button type="object" name="req_approve" class="oe_highlight"
                            string="Request For Approval"
                            groups="motoreign_marketplace.motoreign_marketplace_req_seller,motoreign_marketplace.motoreign_marketplace_admin"
                            invisible="state != 'new'"/>
                    <button type="object" name="reject_seller" class="oe_highlight"
                            string="Reject"
                            invisible="state != 'Pending for Approval'"
                            groups="motoreign_marketplace.motoreign_marketplace_admin"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="Pending for Approval,Approved,Denied"/>
                </header>
            </xpath>
        </field>
    </record>

    <record id="multi_vendor_sellers_view_kanban" model="ir.ui.view">
        <field name="name">multi.vendor.sellers.view.kanban</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="state" readonly="1"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_image me-1">
                                <field name="image_1920" widget="image"/>
                            </div>
                            <div class="oe_kanban_details">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                                <div>Commission: <field name="total_commission"/></div>
                                <div>Status: <field name="state"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <menuitem id="seller_roott" name="My Profile" sequence="1"
              action="action_new_res_partner"
              groups="motoreign_marketplace.motoreign_marketplace_req_seller,motoreign_marketplace.motoreign_marketplace_seller"
              web_icon="motoreign_marketplace,static/description/icon.png"/>

    <menuitem id="seller_root" name="Seller Dashboard" sequence="1"
              action="seller_dashboard_action"
              groups="motoreign_marketplace.motoreign_marketplace_admin"
              web_icon="motoreign_marketplace,static/description/icon.png"/>

    <menuitem id="sales" parent="seller_root" name="Sales" sequence="21"
              groups="motoreign_marketplace.motoreign_marketplace_admin,motoreign_marketplace.motoreign_marketplace_seller"
              action="vendor_dashboard_action"/>

    <menuitem id="dashboard" parent="seller_root" name="Dashboard" sequence="3"
              groups="motoreign_marketplace.motoreign_marketplace_admin,motoreign_marketplace.motoreign_marketplace_seller"
              action="seller_dashboard_action"/>

    <menuitem id="seller" parent="seller_root" name="Seller" sequence="10"
              groups="motoreign_marketplace.motoreign_marketplace_admin,motoreign_marketplace.motoreign_marketplace_seller"
              action="motoreign_marketplace.res_partner_action"/>

    <menuitem id="seller_ecom" parent="seller" name="Sellers" sequence="13"
              groups="motoreign_marketplace.motoreign_marketplace_admin"
              action="res_partner_action"/>

    <menuitem id="my_profile" parent="seller" name="My Profile" sequence="14"
              groups="motoreign_marketplace.motoreign_marketplace_seller"
              action="action_res_partner"/>

    <menuitem id="seller_bill_sales" parent="sales" name="Seller Bill" sequence="29"
              groups="motoreign_marketplace.motoreign_marketplace_admin"
              action="vendor_dashboard_action"/>

    <menuitem id="invoice" parent="seller_root" name="Invoice" sequence="40"
              groups="motoreign_marketplace.motoreign_marketplace_admin"
              action="vendor_dashboard_action"/>

    <menuitem id="seller_bill" parent="invoice" name="Seller Bill" sequence="41"
              groups="motoreign_marketplace.motoreign_marketplace_admin"
              action="account.action_move_in_invoice_type"/>

    <menuitem id="payment" parent="invoice" name="Payment" sequence="42"
              groups="motoreign_marketplace.motoreign_marketplace_admin"
              action="account.action_account_payments_payable"/>
</odoo>
