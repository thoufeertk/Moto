<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seller_payment_action" model="ir.actions.act_window">
        <field name="name">Seller Payment</field>
        <field name="res_model">seller.payment</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="seller_payment_view_tree" model="ir.ui.view">
        <field name="name">seller.payment.view.list</field>
        <field name="model">seller.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="seller_id"/>
                <field name="payment_mode"/>
                <field name="memo"/>
                <field name="payable_amount"/>
                <field name="date"/>
                <field name="type_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>
    <record id="seller_payment_view_form" model="ir.ui.view">
        <field name="name">seller.payment.view.form</field>
        <field name="model">seller.payment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="validate" class="oe_highlight" string="Validate"
                            invisible="state != 'Requested'" type="object"
                            groups="motoreign_marketplace.motoreign_marketplace_admin"/>
                    <button name="reject" class="oe_highlight" string="Reject"
                            invisible="state != 'Requested'" type="object"
                            groups="motoreign_marketplace.motoreign_marketplace_admin"/>
                    <button name="request" type="object" string="Request"
                            class="oe_highlight" invisible="state != 'Draft'"
                            groups="motoreign_marketplace.motoreign_marketplace_seller,motoreign_marketplace.motoreign_marketplace_admin"/>
                    <button name="cancel" type="object" string="Cancel" invisible="state != 'Draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="Draft,Requested,Validated,Rejected"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="seller_id"/>
                            <field name="payment_mode"/>
                            <field name="memo"/>
                            <field name="commission"/>
                            <field name="payable_amount"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="type_id"/>
                            <field name="invoice_cashable"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="description" string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="seller_payment_view_search" model="ir.ui.view">
        <field name="name">seller.payment.view.search</field>
        <field name="model">seller.payment</field>
        <field name="arch" type="xml">
            <search string="Search Payments">
                <field name="seller_id"/>
                <field name="memo"/>
                <filter string="Draft" name="draft" domain="[('state','=','Draft')]"/>
                <filter string="Requested" name="requested" domain="[('state','=','Requested')]"/>
                <filter string="Validated" name="validated" domain="[('state','=','Validated')]"/>
                <separator/>
                <filter string="Group by Seller" name="seller" context="{'group_by': 'seller_id'}"/>
            </search>
        </field>
    </record>
    <record id="seller_payment_sequence" model="ir.sequence">
        <field name="name">Seller Payment Reference</field>
        <field name="code">seller.payment</field>
        <field name="prefix">SP</field>
        <field name="padding">5</field>
    </record>
    <menuitem id="seller_payment" parent="sales" name="Seller Payment" sequence="27"
              groups="motoreign_marketplace.motoreign_marketplace_admin,motoreign_marketplace.motoreign_marketplace_seller"
              action="motoreign_marketplace.seller_payment_action"/>
</odoo>
