<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--    Templates for seller page in the website-->
    <template id="sell_page" name="SellPage">
        <t t-call="website.layout">
            <style>
                .sell_hero_section {
                    position: relative;
                    min-height: 550px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background-image: linear-gradient(rgba(0, 0, 0, 0.45), rgba(0, 0, 0, 0.45)), url('/motoreign_marketplace/static/src/img/marketplace_banner_premium.png');
                    background-size: cover;
                    background-position: center;
                    color: white;
                    text-align: center;
                    margin-bottom: 4rem;
                }
                .hero_content h1 {
                    font-size: 3.5rem;
                    font-weight: 700;
                    margin-bottom: 1.5rem;
                    text-shadow: 0 2px 10px rgba(0,0,0,0.3);
                }
                .hero_content p {
                    font-size: 1.25rem;
                    max-width: 800px;
                    margin: 0 auto 2.5rem;
                    opacity: 0.95;
                }
                .hero_cta_btn {
                    padding: 1rem 2.5rem;
                    font-size: 1.1rem;
                    font-weight: 600;
                    background: #3BD3F4;
                    border: none;
                    border-radius: 50px;
                    color: white;
                    text-transform: uppercase;
                    letter-spacing: 1px;
                    transition: all 0.3s ease;
                    box-shadow: 0 4px 15px rgba(59, 211, 244, 0.4);
                    text-decoration: none;
                }
                .hero_cta_btn:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 8px 25px rgba(59, 211, 244, 0.5);
                    color: white;
                    background: #2bc3e4;
                }
                .section_title {
                    font-weight: 700;
                    color: #243c64;
                    margin-bottom: 3.5rem;
                }
                .feature_card {
                    background: white;
                    border-radius: 16px;
                    padding: 2.5rem;
                    text-align: center;
                    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
                    height: 100%;
                    border: 1px solid rgba(0,0,0,0.05);
                    box-shadow: 0 10px 30px rgba(0,0,0,0.02);
                }
                .feature_card:hover {
                    transform: translateY(-12px);
                    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
                }
                .feature_icon_box {
                    width: 90px;
                    height: 90px;
                    margin: 0 auto 2rem;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    background: #f0faff;
                    border-radius: 20px;
                    transition: background 0.3s ease;
                }
                .feature_card:hover .feature_icon_box {
                    background: #e1f5fe;
                }
                .feature_icon {
                    max-height: 50px;
                    object-fit: contain;
                }
                .feature_name {
                    font-size: 1.5rem;
                    font-weight: 600;
                    color: #243c64;
                    margin-bottom: 1rem;
                }
                .feature_desc {
                    color: #6c757d;
                    line-height: 1.6;
                    font-size: 1rem;
                }
            </style>

            <section class="sell_hero_section">
                <div class="container hero_content">
                    <h1 class="o_default_snippet_text">Start Your Global Selling Journey</h1>
                    <p class="o_default_snippet_text">More than 5,000 professional sellers are already growing their business with us. Join the marketplace and reach millions of customers today.</p>
                    <t t-if="config.get('bcome_seller') and not is_seller">
                        <a href="/seller_reg" class="btn hero_cta_btn o_default_snippet_text">Open a New Store</a>
                    </t>
                </div>
            </section>

            <div class="container py-5 mb-5">
                <h2 class="text-center section_title o_default_snippet_text">Still selling offline? Take your business online with us!</h2>
                <div class="row g-4 justify-content-center">
                    <div class="col-lg-4 col-md-6 o_colored_level">
                        <div class="feature_card">
                            <div class="feature_icon_box">
                                <img src="/motoreign_marketplace/static/src/img/icon.png" class="feature_icon" alt="Open Shop"/>
                            </div>
                            <h3 class="feature_name o_default_snippet_text">Open a New Shop</h3>
                            <p class="feature_desc o_default_snippet_text">By opening a shop at our marketplace you can expose more of your products to more potential customers. Your best opportunity for growth could be selling in our online marketplace.</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 o_colored_level">
                        <div class="feature_card">
                            <div class="feature_icon_box">
                                <img src="/motoreign_marketplace/static/src/img/icon.png" class="feature_icon" alt="Sell Products"/>
                            </div>
                            <h3 class="feature_name o_default_snippet_text">Sell Products</h3>
                            <p class="feature_desc o_default_snippet_text">Business is all about trading. It's all about creating a product so good that people pay for it. Increase your sales figure from our high traffic channel.</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 o_colored_level">
                        <div class="feature_card">
                            <div class="feature_icon_box">
                                <img src="/motoreign_marketplace/static/src/img/icon.png" class="feature_icon" alt="Commission"/>
                            </div>
                            <h3 class="feature_name o_default_snippet_text">Get Quick Commission</h3>
                            <p class="feature_desc o_default_snippet_text">Be smart and start earning the commission whenever a product of yours is sold through our website. Commission Management provides full transparency and flexibility for both buy-side and sell-side.</p>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
    <template id="seller_footer" inherit_id="website.footer_custom"
              name="seller_footer" active="True">
        <xpath expr="//ul[hasclass('list-unstyled')]" position="inside">
            <t t-set="sell"
               t-value="request.env['ir.config_parameter'].sudo().get_param('motoreign_marketplace.show_sell_menu_footer')"/>
            <t t-set="seller_list"
               t-value="request.env['ir.config_parameter'].sudo().get_param('motoreign_marketplace.show_sellers_list')"/>
            <t t-set="seller_label"
               t-value="request.env['ir.config_parameter'].sudo().get_param('motoreign_marketplace.sell_link_label')"/>
            <t t-set="seller_list_label"
               t-value="request.env['ir.config_parameter'].sudo().get_param('motoreign_marketplace.seller_list_link_label')"/>
            <t t-if="sell and (sell == 'True' or sell == '1')">
                <t t-if="seller_label">
                    <li>
                        <a href="/sell">
                            <t t-esc="seller_label"/>
                        </a>
                    </li>
                </t>
                <t t-else="">
                    <li>
                        <a href="/sell">
                            Sell
                        </a>
                    </li>
                </t>
            </t>
            <t t-if="seller_list and (seller_list == 'True' or seller_list == '1')">
                <t t-if="seller_list_label">
                    <li>
                        <a href="/seller/list">
                            <t t-esc="seller_list_label"/>
                        </a>
                    </li>
                </t>
                <t t-else="">
                    <li>
                        <a href="/seller/list">Seller List</a>
                    </li>
                </t>
            </t>
        </xpath>
    </template>
</odoo>
