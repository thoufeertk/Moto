<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">
    <t t-name="multi_vendor_marketplace.SellerDashboard">
        <div class="o_action container-fluid">

            <div class="row mt-3 mb-2">
                <div class="col-12"><h5 class="text-muted">Products</h5></div>
                <div class="col-md-4">
                    <div class="card text-center border-warning cursor-pointer" t-on-click="() => openProducts('pending')">
                        <div class="card-body"><h3 class="text-warning" t-esc="state.pending"/><p class="mb-0">Pending</p></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-success cursor-pointer" t-on-click="() => openProducts('approved')">
                        <div class="card-body"><h3 class="text-success" t-esc="state.approved"/><p class="mb-0">Approved</p></div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center border-danger cursor-pointer" t-on-click="() => openProducts('rejected')">
                        <div class="card-body"><h3 class="text-danger" t-esc="state.rejected"/><p class="mb-0">Rejected</p></div>
                    </div>
                </div>
            </div>

            <div class="row mt-3 mb-2">
                <div class="col-12"><h5 class="text-muted">Orders</h5></div>
                <div class="col-md-3">
                    <div class="card text-center border-warning cursor-pointer" t-on-click="() => openOrders('pending')">
                        <div class="card-body"><h3 class="text-warning" t-esc="state.order_pending"/><p class="mb-0">Pending</p></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-info cursor-pointer" t-on-click="() => openOrders('approved')">
                        <div class="card-body"><h3 class="text-info" t-esc="state.order_approved"/><p class="mb-0">Approved</p></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-success cursor-pointer" t-on-click="() => openOrders('shipped')">
                        <div class="card-body"><h3 class="text-success" t-esc="state.order_shipped"/><p class="mb-0">Shipped</p></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card text-center border-danger cursor-pointer" t-on-click="() => openOrders('cancel')">
                        <div class="card-body"><h3 class="text-danger" t-esc="state.order_cancel"/><p class="mb-0">Cancelled</p></div>
                    </div>
                </div>
            </div>

            <t t-if="state.user_type">
                <div class="row mt-3 mb-2">
                    <div class="col-12"><h5 class="text-muted">Sellers</h5></div>
                    <div class="col-md-4">
                        <div class="card text-center border-warning cursor-pointer" t-on-click="() => openSellers('Pending for Approval')">
                            <div class="card-body"><h3 class="text-warning" t-esc="state.seller_pending"/><p class="mb-0">Pending</p></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center border-success cursor-pointer" t-on-click="() => openSellers('Approved')">
                            <div class="card-body"><h3 class="text-success" t-esc="state.seller_approved"/><p class="mb-0">Approved</p></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center border-danger cursor-pointer" t-on-click="() => openSellers('Denied')">
                            <div class="card-body"><h3 class="text-danger" t-esc="state.seller_rejected"/><p class="mb-0">Rejected</p></div>
                        </div>
                    </div>
                </div>

                <div class="row mt-3 mb-2">
                    <div class="col-12"><h5 class="text-muted">Payments</h5></div>
                    <div class="col-md-4">
                        <div class="card text-center border-warning cursor-pointer" t-on-click="() => openPayments('Requested')">
                            <div class="card-body"><h3 class="text-warning" t-esc="state.payment_pending"/><p class="mb-0">Requested</p></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center border-success cursor-pointer" t-on-click="() => openPayments('Validated')">
                            <div class="card-body"><h3 class="text-success" t-esc="state.payment_approved"/><p class="mb-0">Validated</p></div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card text-center border-danger cursor-pointer" t-on-click="() => openPayments('Rejected')">
                            <div class="card-body"><h3 class="text-danger" t-esc="state.payment_rejected"/><p class="mb-0">Rejected</p></div>
                        </div>
                    </div>
                </div>
            </t>

        </div>
    </t>
</templates>
